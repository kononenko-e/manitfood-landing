---
// §3 Развилка «Что вы делаете?» + §4 Сегмент-зона (морфинг Заведение ⇄ Дом).
// Единый каркас, морфятся контент и подтема (studio-dark / home-warm).
// Дефолт — «Заведение» (решено в структуре, §9).

const segments = [
  {
    id: 'cafe',
    theme: 'studio-dark',
    cardTitle: 'У меня заведение / бизнес',
    cardDesc: 'Кафе, рестораны, доставка, крупный кейтеринг',
    cardImage: '/images/after/burger.jpg',
    cardAlt: 'Ресторанная подача блюда — сегмент «Заведение»',
    painTitle: 'Фотограф — от 3 000 ₽ за блюдо. А меню меняется каждый сезон',
    pain: 'Профессиональная съёмка стоит 3 000–15 000 ₽ и устаревает вместе с сезонным меню. Новая позиция — снова студия, свет, согласования и дни ожидания.',
    promise:
      'Манит делает студийный кадр из снимка на телефон за минуты — по цене одной позиции в чеке. Меню, сайт, агрегаторы и реклама всегда со свежими фото.',
    proofBefore: '/images/before/burger.jpg',
    proofAfter: '/images/after/burger.jpg',
    proofAltBefore: 'Бургер из меню, снятый на телефон — до',
    proofAltAfter: 'Тот же бургер после обработки Манит — студийная подача',
    proofCaption: 'позиция меню · стиль: светлый и воздушный',
  },
  {
    id: 'home',
    theme: 'home-warm',
    cardTitle: 'Я готовлю сам / небольшой бренд',
    cardDesc: 'Домашние кондитеры, цеха, частный кейтеринг',
    cardImage: '/images/after/cake.jpg',
    cardAlt: 'Домашний торт с хорошим светом — сегмент «Дом / малый бренд»',
    painTitle: 'Постишь каждый день, а свет дома не тот',
    pain: 'Соцсети и Авито требуют фото постоянно, но дома нет студийного света и композиции. При этом глянец только вредит: покупатель должен узнать именно тот торт, который закажет.',
    promise:
      'Манит оставляет блюдо настоящим — убирает случайный свет, тени и лишний фон. Получается честный кадр «как из портфолио», а не пластиковый ИИ-глянец.',
    proofBefore: '/images/before/cake.jpg',
    proofAfter: '/images/after/cake.jpg',
    proofAltBefore: 'Домашний торт, снятый на кухне — до',
    proofAltAfter: 'Тот же торт после обработки Манит — свет и композиция портфолио',
    proofCaption: 'торт на заказ · стиль: домашний рустик',
  },
];
---

<!-- §3. Развилка — master-мир -->
<section id="segments" class="bg-base-100 pt-24 pb-14 md:pt-32">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <h2 class="max-w-2xl text-3xl font-semibold tracking-tight md:text-[2.5rem] md:leading-tight">
      Что вы делаете? Покажем, как это работает именно для вас
    </h2>

    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2">
      {segments.map((s, i) => (
        <button
          type="button"
          class="segment-card group relative block overflow-hidden rounded-sm text-left shadow-frame-warm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          data-segment={s.id}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <img
            src={s.cardImage}
            alt={s.cardAlt}
            class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-neutral/85 via-neutral/25 to-transparent transition-colors duration-300 group-hover:via-neutral/40"></div>
          <span class="segment-mark badge badge-primary absolute right-4 top-4 rounded-none font-mono text-xs font-medium uppercase tracking-widest">
            выбрано
          </span>
          <div class="absolute inset-x-0 bottom-0 p-5 md:p-6">
            <h3 class="text-xl font-semibold text-neutral-content md:text-2xl">{s.cardTitle}</h3>
            <p class="mt-1 text-sm text-neutral-content/75">{s.cardDesc}</p>
          </div>
          <span class="segment-frame pointer-events-none absolute inset-0 border-[3px] border-primary opacity-0 transition-opacity duration-300" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- §4. Сегмент-зона — морфинг подтемы на месте -->
<section id="segment-zone" class="morph-zone bg-base-100 py-20 md:py-28" data-theme="studio-dark">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <div class="relative">
      {segments.map((s, i) => (
        <article
          class="segment-content grid grid-cols-1 items-center gap-12 md:grid-cols-2"
          data-segment-content={s.id}
          data-inactive={i === 0 ? undefined : ''}
        >
          <div>
            <span class="badge badge-primary rounded-none font-mono text-xs font-medium uppercase tracking-widest">
              {s.id === 'cafe' ? 'заведениям и бизнесу' : 'дому и малому бренду'}
            </span>
            <h3 class="mt-5 text-2xl font-semibold leading-tight tracking-tight md:text-4xl">{s.painTitle}</h3>
            <p class="mt-5 text-base-content/70 md:text-lg">{s.pain}</p>
            <p class="mt-4 text-base-content md:text-lg">{s.promise}</p>
            <a href="#how" class="btn btn-ghost mt-8 rounded-sm border border-base-300 font-medium">
              Как это работает ↓
            </a>
          </div>

          <!-- 1 сильный пруф под сегмент -->
          <figure>
            <div class="grid grid-cols-2 gap-3">
              <div class="relative">
                <img src={s.proofBefore} alt={s.proofAltBefore} class="morph-surface aspect-[4/5] w-full rounded-sm object-cover shadow-frame-dark" loading="lazy" />
                <span class="badge badge-secondary absolute left-2.5 top-2.5 rounded-none font-mono text-[0.7rem] font-medium uppercase tracking-widest">до</span>
              </div>
              <div class="relative">
                <img src={s.proofAfter} alt={s.proofAltAfter} class="morph-surface aspect-[4/5] w-full rounded-sm object-cover shadow-frame-dark ring-2 ring-primary" loading="lazy" />
                <span class="badge badge-primary absolute left-2.5 top-2.5 rounded-none font-mono text-[0.7rem] font-medium uppercase tracking-widest">после</span>
              </div>
            </div>
            <figcaption class="mt-3 font-mono text-xs font-medium tracking-widest text-base-content/60">
              {s.proofCaption}
            </figcaption>
          </figure>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  function initSegments() {
    const zone = document.getElementById('segment-zone');
    const cards = document.querySelectorAll<HTMLButtonElement>('.segment-card');
    const contents = document.querySelectorAll<HTMLElement>('[data-segment-content]');
    if (!zone || cards.length === 0) return;

    const themes: Record<string, string> = { cafe: 'studio-dark', home: 'home-warm' };

    function select(id: string) {
      const theme = themes[id] ?? 'studio-dark';
      zone!.dataset.theme = theme;
      // Секция «Как это работает» живёт в теме выбранного сегмента (решение автора):
      // конфигуратор наследует тот же мир, что и сегмент-зона выше.
      document.dispatchEvent(new CustomEvent('manit:segment', { detail: theme }));
      cards.forEach((c) => c.setAttribute('aria-pressed', c.dataset.segment === id ? 'true' : 'false'));
      contents.forEach((el) => {
        if (el.dataset.segmentContent === id) {
          el.removeAttribute('data-inactive');
        } else {
          el.setAttribute('data-inactive', '');
        }
      });
    }

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    cards.forEach((card) => {
      card.addEventListener('click', () => {
        select(card.dataset.segment!);
        zone!.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'nearest' });
      });
    });
  }

  initSegments();
</script>

<style>
  /* активная карточка развилки: лаймовая обводка-«отметка» + бейдж */
  .segment-card .segment-mark {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .segment-card[aria-pressed='true'] .segment-frame,
  .segment-card[aria-pressed='true'] .segment-mark {
    opacity: 1;
  }
</style>
