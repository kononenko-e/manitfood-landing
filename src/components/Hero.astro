---
import { BOT_URL, CTA_LABEL } from '@/lib/site';
---

<!-- §1. Hero: общее обещание для всех, до развилки. Master-мир.
     Иерархия сессии: слоган-«шапка» на всю ширину — единственная гигантская строка
     страницы; функциональный h1 сознательно ступенькой ниже, чтобы две крупные
     строки не спорили. Слово «манит» уезжает по скроллу в хедер (морфинг лого).
     Правая колонка — живая пара «до/после» (без слайдера); объяснение в 3 шага и
     подробный подзаголовок — в следующем блоке §1a. -->
<section id="top" class="relative overflow-hidden bg-base-100 pt-28 pb-20 md:pt-40 md:pb-28">
  <!-- мягкий световой спот, не перегруженный фон -->
  <div
    class="pointer-events-none absolute -top-32 right-[-10%] h-[36rem] w-[36rem] rounded-full opacity-25 blur-3xl"
    style="background: radial-gradient(circle, #D6F23C 0%, transparent 65%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-4 md:px-8">
    <!-- Слоган-«шапка» на всю ширину. «манит» — та же величина, что «но не обманывает»
         (пожелание автора), но акцент на слове держит начертание bold + лаймовая «а»;
         хвост слогана — то же кегль, но легче (medium) и приглушён, чтобы не перетягивать.
         Запятая идёт сразу за словом, а «но не обманывает» — со следующей строки.
         При скролле «манит» уезжает в хедер, а запятая и хвост синхронно гаснут. -->
    <div id="hero-logo-row" class="mb-10 md:mb-14">
      <div class="flex items-baseline">
        <div id="hero-logo-box">
          <a
            id="hero-logo"
            href="#top"
            class="relative z-[60] inline-block text-6xl font-bold lowercase leading-none tracking-tight md:text-8xl"
            aria-label="Манит — на начало страницы"
          >
            м<span class="text-primary">а</span>нит
          </a>
        </div>
        <span
          id="hero-comma"
          class="text-6xl font-medium leading-none tracking-tight text-base-content/45 md:text-8xl"
          aria-hidden="true"
        >,</span>
      </div>
      <p
        id="hero-tagline"
        class="mt-1 text-6xl font-medium leading-none tracking-tight text-base-content/45 md:text-8xl"
      >
        но&nbsp;не обманывает
      </p>
    </div>

    <!-- Питч + пара «до/после» -->
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-10">
      <!-- Текст-колонка: только заголовок и кнопки (подробности — в блоке §1a ниже) -->
      <div>
        <h1 class="max-w-md text-4xl font-bold leading-[1.05] tracking-tight md:text-5xl">
          Бот для фуд-фото
        </h1>
        <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
          <a href={BOT_URL} target="_blank" rel="noopener" class="btn btn-primary btn-lg rounded-full px-9 shadow-shutter">
            {CTA_LABEL}
          </a>
          <a href="#how-steps" class="btn btn-ghost btn-lg rounded-sm border border-base-300 px-7 font-medium">
            Посмотреть как
          </a>
        </div>
        <p class="mt-4 font-mono text-sm font-medium text-base-content/70">
          первое фото — бесплатно · без карты
        </p>
      </div>

      <!-- Визуал-колонка: живая пара «до/после» без слайдера, просто рядом -->
      <figure class="mx-auto w-full max-w-md">
        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <div class="relative">
            <img
              src="/images/before/burger.jpg"
              alt="Обычный снимок бургера на телефон — до"
              class="aspect-[4/5] w-full rounded-sm object-cover shadow-frame-warm"
              width="320"
              height="400"
              loading="eager"
              fetchpriority="high"
            />
            <span class="badge badge-secondary absolute left-2.5 top-2.5 rounded-none font-mono text-[0.7rem] font-medium uppercase tracking-widest">до</span>
          </div>
          <div class="relative">
            <img
              src="/images/after/burger.jpg"
              alt="Тот же бургер после обработки Манит — студийное фото"
              class="aspect-[4/5] w-full rounded-sm object-cover shadow-frame-warm ring-2 ring-primary"
              width="320"
              height="400"
              loading="eager"
              fetchpriority="high"
            />
            <span class="badge badge-primary absolute left-2.5 top-2.5 rounded-none font-mono text-[0.7rem] font-medium uppercase tracking-widest">после</span>
          </div>
        </div>
        <figcaption class="mt-3 text-center text-xs text-base-content/50">
          Пример иллюстративный · то&nbsp;же блюдо
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<script>
  // Морфинг логотипа: слово «манит» уезжает из хиро в хедер, синхронно со скроллом,
  // и достраивает там лого рядом со статичной иконкой. Слоган-хвост в хиро гаснет
  // по ходу того же скролла, чтобы не остаться висеть в одиночестве без слова.
  function initLogoMorph() {
    const logo = document.getElementById('hero-logo');
    const box = document.getElementById('hero-logo-box');
    const slotText = document.getElementById('header-logo-text');
    const tagline = document.getElementById('hero-tagline');
    const comma = document.getElementById('hero-comma');
    if (!logo || !box || !slotText) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.documentElement.classList.add('logo-morph');

    let heroTop = 0;
    let heroLeft = 0;
    let slotTop = 0;
    let slotLeft = 0;
    let scaleK = 1;
    let dockAt = 1;

    function update() {
      const y = window.scrollY;
      const p = Math.max(0, Math.min(1, y / dockAt));
      // хвост слогана и запятая гаснут быстрее самого переезда — к середине пути они
      // уже почти невидимы, чтобы крупная строка «но не обманывает» не висела одна
      const tailOpacity = String(Math.max(0, 1 - p * 1.8));
      if (tagline) tagline.style.opacity = tailOpacity;
      if (comma) comma.style.opacity = tailOpacity;
      if (p >= 1) {
        // пристыкован: фиксируется точно на месте слова в хедере, рядом с иконкой
        logo!.classList.add('is-docked');
        logo!.style.top = slotTop + 'px';
        logo!.style.left = slotLeft + 'px';
        logo!.style.transform = `scale(${scaleK})`;
      } else {
        logo!.classList.remove('is-docked');
        logo!.style.top = '';
        logo!.style.left = '';
        const naturalTop = heroTop - y;
        const dx = (slotLeft - heroLeft) * p;
        const dy = (slotTop - naturalTop) * p;
        const k = 1 + (scaleK - 1) * p;
        logo!.style.transform = `translate(${dx}px, ${dy}px) scale(${k})`;
      }
    }

    function measure() {
      const wasDocked = logo!.classList.contains('is-docked');
      logo!.classList.remove('is-docked');
      logo!.style.transform = 'none';
      logo!.style.top = '';
      logo!.style.left = '';
      const r = logo!.getBoundingClientRect();
      box!.style.width = r.width + 'px'; // место в потоке для слогана рядом
      box!.style.height = r.height + 'px'; // и на время фиксации
      heroTop = r.top + window.scrollY;
      heroLeft = r.left;
      const s = slotText!.getBoundingClientRect(); // хедер фиксирован — координаты вьюпорта
      slotTop = s.top;
      slotLeft = s.left;
      scaleK = s.width / r.width;
      dockAt = Math.max(1, heroTop - slotTop);
      if (wasDocked) logo!.classList.add('is-docked');
      update();
    }

    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', measure);
    document.fonts?.ready.then(measure);

    // иконка в хедере — svg-картинка; до её загрузки ширина неизвестна браузеру,
    // а от неё зависит позиция текстового слота рядом — домеряем повторно после загрузки
    const headerIcon = document.querySelector<HTMLImageElement>('#header-logo-anchor img');
    headerIcon?.decode().catch(() => {}).then(measure);

    measure();
  }

  initLogoMorph();
</script>

<style>
  #hero-logo {
    transform-origin: top left;
    will-change: transform;
  }
  #hero-logo.is-docked {
    position: fixed;
  }
  /* хвост слогана и запятая переезжают вместе с высотой строки — сглаживаем гашение */
  #hero-tagline,
  #hero-comma {
    transition: opacity 0.1s linear;
    will-change: opacity;
  }
</style>
