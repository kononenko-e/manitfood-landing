---
import { BOT_URL, CTA_LABEL } from '@/lib/site';
---

<!-- §1. Hero: общее обещание для всех, до развилки. Master-мир. -->
<section id="top" class="relative overflow-hidden bg-base-100 pt-28 pb-20 md:pt-40 md:pb-28">
  <!-- мягкий световой спот, не перегруженный фон -->
  <div
    class="pointer-events-none absolute -top-32 right-[-10%] h-[36rem] w-[36rem] rounded-full opacity-25 blur-3xl"
    style="background: radial-gradient(circle, #D6F23C 0%, transparent 65%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-14 px-4 md:grid-cols-2 md:gap-10 md:px-8">
    <!-- Текст-колонка -->
    <div>
      <!-- крупный логотип; при скролле уменьшается и пристыковывается в хедер -->
      <div id="hero-logo-box" class="mb-10">
        <a
          id="hero-logo"
          href="#top"
          class="relative z-[60] inline-block"
          aria-label="Манит — на начало страницы"
        >
          <img src="/logo.svg" alt="" aria-hidden="true" class="h-14 w-auto md:h-20" />
        </a>
      </div>
      <h1 class="text-4xl font-bold leading-[1.08] tracking-tight md:text-[3.4rem]">
        Фото блюда с&nbsp;телефона — как из фотостудии
      </h1>
      <p class="mt-6 max-w-xl text-lg text-base-content/70 md:text-xl">
        Загрузите обычный снимок — бот вернёт профессиональное фото для меню, доставки
        и соцсетей. Без фотографа, реквизита и ожидания.
      </p>
      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        <a href={BOT_URL} target="_blank" rel="noopener" class="btn btn-primary btn-lg rounded-full px-9 shadow-shutter">
          {CTA_LABEL}
        </a>
        <a href="#demo" class="btn btn-ghost btn-lg rounded-sm border border-base-300 px-7 font-medium">
          Посмотреть как
        </a>
      </div>
      <p class="mt-4 font-mono text-sm font-medium text-base-content/70">
        первое фото — бесплатно · без карты
      </p>
    </div>

    <!-- Визуал-колонка: мокап Telegram-бота (акцентный якорь первого экрана) -->
    <div class="mx-auto w-full max-w-sm">
      <div class="rounded-[1.75rem] border border-base-300 bg-base-100 p-3 shadow-frame-warm">
        <div class="rounded-[1.25rem] bg-base-200 p-4">
          <!-- шапка чата -->
          <div class="flex items-center gap-3 border-b border-base-300 pb-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-neutral font-bold lowercase text-primary">м</div>
            <div>
              <p class="text-sm font-semibold leading-tight">Манит</p>
              <p class="text-xs leading-tight text-base-content/50">бот · онлайн</p>
            </div>
          </div>
          <!-- диалог -->
          <div class="mt-4 space-y-3">
            <div class="chat chat-end">
              <div class="chat-bubble max-w-[13rem] bg-base-300 p-1.5 text-base-content">
                <img
                  src="/images/before/burger.jpg"
                  alt="Обычный снимок бургера на телефон, отправленный в бота"
                  class="w-full rounded-sm object-cover aspect-[4/3]"
                  width="416"
                  height="312"
                  loading="eager"
                  fetchpriority="high"
                />
                <p class="px-1 py-1 text-xs text-base-content/70">Снял на телефон как есть</p>
              </div>
            </div>
            <div class="chat chat-start">
              <div class="chat-bubble bg-base-100 text-sm text-base-content">
                Принял! Стиль — «Тёмная драма», локация — «Студия». Снимаю&nbsp;⏳
              </div>
            </div>
            <div class="chat chat-start">
              <div class="chat-bubble max-w-[13rem] bg-base-100 p-1.5 text-base-content">
                <img
                  src="/images/after/burger.jpg"
                  alt="Готовое профессиональное фото того же бургера от бота Манит"
                  class="w-full rounded-sm object-cover aspect-[4/3] ring-2 ring-primary"
                  width="416"
                  height="312"
                  loading="eager"
                  fetchpriority="high"
                />
                <p class="px-1 pt-1.5 font-mono text-[0.7rem] font-medium text-base-content/70">
                  готово · 01:34 · 4K · без вотермарки
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <p class="mt-3 text-center text-xs text-base-content/50">Диалог иллюстративный</p>
    </div>
  </div>
</section>

<script>
  // Морфинг логотипа: из хиро — в слот хедера, синхронно со скроллом.
  function initLogoMorph() {
    const logo = document.getElementById('hero-logo');
    const box = document.getElementById('hero-logo-box');
    const slot = document.getElementById('header-logo-anchor');
    if (!logo || !box || !slot) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.documentElement.classList.add('logo-morph');

    let heroTop = 0;
    let heroLeft = 0;
    let slotTop = 0;
    let slotLeft = 0;
    let scaleK = 1;
    let dockAt = 1;

    function update() {
      const y = window.scrollY;
      const p = Math.max(0, Math.min(1, y / dockAt));
      if (p >= 1) {
        // пристыкован: фиксируется точно на месте логотипа в хедере
        logo!.classList.add('is-docked');
        logo!.style.top = slotTop + 'px';
        logo!.style.left = slotLeft + 'px';
        logo!.style.transform = `scale(${scaleK})`;
      } else {
        logo!.classList.remove('is-docked');
        logo!.style.top = '';
        logo!.style.left = '';
        const naturalTop = heroTop - y;
        const dx = (slotLeft - heroLeft) * p;
        const dy = (slotTop - naturalTop) * p;
        const k = 1 + (scaleK - 1) * p;
        logo!.style.transform = `translate(${dx}px, ${dy}px) scale(${k})`;
      }
    }

    function measure() {
      const wasDocked = logo!.classList.contains('is-docked');
      logo!.classList.remove('is-docked');
      logo!.style.transform = 'none';
      logo!.style.top = '';
      logo!.style.left = '';
      const r = logo!.getBoundingClientRect();
      box!.style.height = r.height + 'px'; // место в потоке на время фиксации
      heroTop = r.top + window.scrollY;
      heroLeft = r.left;
      const s = slot!.getBoundingClientRect(); // хедер фиксирован — координаты вьюпорта
      slotTop = s.top;
      slotLeft = s.left;
      scaleK = s.width / r.width;
      dockAt = Math.max(1, heroTop - slotTop);
      if (wasDocked) logo!.classList.add('is-docked');
      update();
    }

    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', measure);
    document.fonts?.ready.then(measure);

    // логотип — svg-картинка; до её загрузки ширина неизвестна браузеру,
    // поэтому домеряем масштаб повторно, когда обе копии (hero + хедер) готовы
    const images = [logo!.querySelector('img'), slot!.querySelector('img')].filter(
      (img): img is HTMLImageElement => !!img,
    );
    Promise.all(images.map((img) => img.decode().catch(() => {}))).then(measure);

    measure();
  }

  initLogoMorph();
</script>

<style>
  #hero-logo {
    transform-origin: top left;
    will-change: transform;
  }
  #hero-logo.is-docked {
    position: fixed;
  }
</style>
