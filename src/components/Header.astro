---
import { BOT_URL, CTA_LABEL } from '@/lib/site';
---

<!-- §0. Sticky-хедер: плоский, без теней, тонкая нижняя обводка (DESIGN §6) -->
<header class="navbar fixed top-0 z-50 min-h-16 border-b border-base-300 bg-base-100/85 px-4 backdrop-blur md:px-8">
  <div class="flex-1">
    <!-- иконка — статичная часть лого, всегда на месте; слово «манит» рядом
         скрыто (visibility) во время морфинга — его место занимает пристыковавшееся
         слово из хиро, а сам текст остаётся для no-JS / reduced-motion -->
    <a id="header-logo-anchor" href="#top" class="relative inline-flex items-center gap-2.5" aria-label="Манит — на начало страницы">
      <img src="/logo-icon.svg" alt="" aria-hidden="true" class="h-8 w-auto shrink-0" />
      <span id="header-logo-text" class="relative inline-block text-3xl font-bold lowercase leading-none tracking-tight">
        м<span class="text-primary">а</span>нит
      </span>
    </a>
  </div>
  <nav class="hidden flex-none items-center gap-1 md:flex" aria-label="Основные разделы">
    <a href="#how" class="btn btn-ghost btn-sm rounded-sm font-medium">Как работает</a>
    <a href="#pricing" class="btn btn-ghost btn-sm rounded-sm font-medium">Тарифы</a>
    <a href="#faq" class="btn btn-ghost btn-sm rounded-sm font-medium">Вопросы</a>
  </nav>
  <div class="flex-none pl-2">
    <a href={BOT_URL} target="_blank" rel="noopener" class="btn btn-primary btn-sm rounded-full px-5 shadow-shutter">
      {CTA_LABEL}
    </a>
  </div>
</header>
