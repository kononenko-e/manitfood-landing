---
import { BOT_URL, CTA_LABEL } from '@/lib/site';
---

<!-- §8. Финальный CTA: спокойный, низко-давящий; единственная секция-финал.
     Тёмный фон — допустимый приём master-мира, фирменный лайм обязателен. -->
<section id="start" class="scroll-mt-20 bg-base-100 py-24 md:py-36" data-theme="studio-dark">
  <div class="mx-auto max-w-3xl px-4 text-center md:px-8">
    <h2 class="text-3xl font-semibold leading-tight tracking-tight md:text-5xl">
      Первое фото — бесплатно.<br />Дальше решите сами
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-lg text-base-content/70">
      Бот спросит, что вы готовите, предложит стиль и сделает кадр за пару минут.
      Карта не нужна, чтобы попробовать.
    </p>
    <div class="mt-10">
      <a href={BOT_URL} target="_blank" rel="noopener" class="btn btn-primary btn-lg rounded-full px-12 shadow-shutter">
        {CTA_LABEL}
      </a>
    </div>
    <p class="mt-6 font-mono text-sm font-medium text-base-content/60">
      без карты · оплата и тарифы — в боте · отмена в любой момент
    </p>
  </div>
</section>
