---
// §2. Живое «до/после»: один кинематографичный пример, reveal сверху вниз при скролле.
// Fallback без JS и при prefers-reduced-motion — статичная пара side-by-side (global.css).
const PAIR = {
  before: '/images/before/pasta.jpg',
  after: '/images/after/pasta.jpg',
};
---

<section id="demo" class="relative bg-neutral" data-theme="studio-dark">
  <!-- Скролл-версия -->
  <div class="ba-scene relative" style="height: 300vh;">
    <div class="ba-sticky sticky top-0 h-screen w-full overflow-hidden" style="--reveal: 0%;">
      <!-- нижний слой: «после» + его этикетка (открывается по мере скролла) -->
      <div class="absolute inset-0">
        <img
          src={PAIR.after}
          alt="Результат Манит: то же блюдо со студийным светом и подачей"
          class="h-full w-full object-cover"
          loading="lazy"
        />
        <span class="badge badge-primary absolute left-6 top-20 rounded-none font-mono text-xs font-medium uppercase tracking-widest md:left-12">
          после — результат манит
        </span>
      </div>
      <!-- верхний слой: «до» + его этикетка (клипуется сверху вниз вместе с фото) -->
      <div class="ba-before absolute inset-0">
        <img
          src={PAIR.before}
          alt="Обычное фото блюда на телефон, до обработки"
          class="h-full w-full object-cover"
          loading="lazy"
        />
        <span class="badge badge-secondary absolute bottom-16 right-6 rounded-none font-mono text-xs font-medium uppercase tracking-widest md:right-12">
          до — обычное фото
        </span>
      </div>

      <!-- линия-«шторка» -->
      <div class="ba-handle absolute inset-x-0 h-px bg-white/70" style="top: var(--reveal, 0%);" aria-hidden="true">
        <div class="absolute left-1/2 top-1/2 flex h-11 -translate-x-1/2 -translate-y-1/2 items-center bg-base-100/90 px-3 font-mono text-xs font-medium tracking-widest text-base-content">
          ↕ листайте
        </div>
      </div>

      <p class="absolute inset-x-0 bottom-5 px-6 text-center">
        <span class="inline-block bg-neutral/80 px-3 py-1.5 text-sm text-neutral-content">
          Пара иллюстративная — реальные «до/после» встанут сюда после первых генераций в боте
        </span>
      </p>
    </div>
  </div>

  <!-- Fallback: статичная пара (no-JS / prefers-reduced-motion) -->
  <div class="ba-fallback px-4 py-20 md:px-8">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 sm:grid-cols-2">
      <figure>
        <div class="relative">
          <img src={PAIR.before} alt="Обычное фото блюда на телефон, до обработки" class="w-full object-cover aspect-[4/3]" loading="lazy" />
          <span class="badge badge-secondary absolute left-3 top-3 rounded-none font-mono text-xs font-medium uppercase tracking-widest">до</span>
        </div>
        <figcaption class="caption-label mt-3 text-base-content/60">обычное фото на телефон</figcaption>
      </figure>
      <figure>
        <div class="relative">
          <img src={PAIR.after} alt="Результат Манит: то же блюдо со студийным светом" class="w-full object-cover aspect-[4/3]" loading="lazy" />
          <span class="badge badge-primary absolute left-3 top-3 rounded-none font-mono text-xs font-medium uppercase tracking-widest">после</span>
        </div>
        <figcaption class="caption-label mt-3 text-base-content/60">результат манит</figcaption>
      </figure>
    </div>
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-base-content/70">
      Пара иллюстративная — реальные «до/после» встанут сюда после первых генераций в боте.
    </p>
  </div>
</section>

<script>
  function initBeforeAfter() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const scene = document.querySelector<HTMLElement>('.ba-scene');
    const sticky = document.querySelector<HTMLElement>('.ba-sticky');
    if (!scene || !sticky) return;

    function update() {
      const rect = scene!.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const progress = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 0;
      sticky!.style.setProperty('--reveal', (progress * 100).toFixed(2) + '%');
    }

    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }

  initBeforeAfter();
</script>
