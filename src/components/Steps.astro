---
// §1a. Как это работает — краткое пояснение в три шага, каждый с иллюстрацией.
// Сюда переехал подробный подзаголовок из hero. Master-мир, светлая тема.
// Иллюстрации: реальные кадры до/после + мини-панель выбора стиля (без псевдоданных).

const steps = [
  {
    n: '01',
    title: 'Загрузите фото',
    desc: 'Обычный снимок блюда с телефона — как есть, без света, штатива и реквизита.',
    kind: 'photo' as const,
    img: '/images/before/burger.jpg',
    alt: 'Обычный снимок бургера на телефон',
  },
  {
    n: '02',
    title: 'Настройте кадр или доверьтесь нам',
    desc: 'Выберите стиль и локацию под задачу — или оставьте выбор боту, он подберёт сам.',
    kind: 'config' as const,
  },
  {
    n: '03',
    title: 'Получите результат',
    desc: 'Профессиональное фото для меню, агрегаторов и соцсетей — за минуты, а не за дни.',
    kind: 'photo' as const,
    img: '/images/after/burger.jpg',
    alt: 'Тот же бургер после обработки Манит — студийное фото',
    highlight: true,
  },
];

// палитра стилей — из конфигуратора (§5), чтобы мини-панель шага 2 читалась как он
const swatches = [
  { g: 'linear-gradient(150deg, #0B0B0D, #3A0E10)', sel: true },
  { g: 'linear-gradient(150deg, #F3F1EA, #CFC6B4)' },
  { g: 'linear-gradient(150deg, #4A2F1C, #C98A4B)' },
  { g: 'linear-gradient(145deg, #26282E, #15161A)' },
];
---

<section id="how-steps" class="scroll-mt-20 bg-base-200 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight md:text-[2.5rem] md:leading-tight">
        Как это работает — три шага
      </h2>
      <p class="mt-4 text-lg text-base-content/70">
        Загрузите обычный снимок — бот вернёт профессиональное фото для меню, агрегаторов
        и&nbsp;соцсетей. Без фотографа, ожидания и&nbsp;переплат.
      </p>
    </div>

    <ol class="mt-12 grid grid-cols-1 gap-8 md:mt-16 md:grid-cols-3 md:gap-6">
      {steps.map((step) => (
        <li class="flex flex-col">
          <!-- Иллюстрация -->
          {step.kind === 'photo' ? (
            <div class="relative overflow-hidden rounded-sm border border-base-300 shadow-frame-warm">
              <img
                src={step.img}
                alt={step.alt}
                class:list={['aspect-[4/3] w-full object-cover', step.highlight && 'ring-2 ring-inset ring-primary']}
                width="480"
                height="360"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="relative aspect-[4/3] w-full overflow-hidden rounded-sm border border-base-300 bg-base-100 p-3 shadow-frame-warm">
              <div class="grid h-full grid-cols-2 grid-rows-2 gap-2">
                {swatches.map((s) => (
                  <div
                    class:list={['rounded-sm', s.sel && 'ring-2 ring-inset ring-primary']}
                    style={`background: ${s.g}`}
                  ></div>
                ))}
              </div>
              <span class="absolute bottom-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-primary px-3 py-1 font-mono text-[0.7rem] font-semibold text-primary-content shadow-shutter">
                стиль · локация · или авто
              </span>
            </div>
          )}

          <!-- Текст шага -->
          <div class="mt-5 flex items-baseline gap-3">
            <span class="font-mono text-sm font-bold tracking-widest text-primary-content">
              <span class="bg-primary px-1.5 py-0.5">{step.n}</span>
            </span>
            <h3 class="text-xl font-semibold leading-tight tracking-tight">{step.title}</h3>
          </div>
          <p class="mt-2 text-base-content/70">{step.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
