---
import { BOT_URL, CTA_LABEL } from '@/lib/site';

// §5. Конфигуратор: блюдо × стиль × локация → готовый кадр.
// Пока нет предгенерированного набора комбинаций (structure §8) — результат
// меняется по блюду, стиль/локация дают превью-эффект (фильтр/подложка)
// с явным дисклеймером. Набор фиксирован: 5 × 4 × 3.

const dishes = [
  { id: 'burger', name: 'Бургер' },
  { id: 'pasta', name: 'Паста' },
  { id: 'cake', name: 'Торт' },
  { id: 'dessert', name: 'Десерт' },
  { id: 'bento', name: 'Бенто-торт' },
];

const styles = [
  { id: 'drama', name: 'Тёмная драма', from: '#0B0B0D', to: '#3A0E10' },
  { id: 'airy', name: 'Светлый и воздушный', from: '#FFFFFF', to: '#DCD4C6' },
  { id: 'rustic', name: 'Домашний рустик', from: '#4A2F1C', to: '#C98A4B' },
  { id: 'fine', name: 'Fine dining', from: '#151312', to: '#5C4A2A' },
];

const locations = [
  { id: 'studio', name: 'Студия' },
  { id: 'marble', name: 'Мрамор' },
  { id: 'wood', name: 'Дерево' },
];
---

<section id="how" class="scroll-mt-20 bg-base-200 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <div class="max-w-2xl">
      <p class="caption-label text-base-content/60">как это работает · <span class="font-mono">3 шага</span></p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-[2.5rem] md:leading-tight">
        Соберите кадр сами — прямо здесь
      </h2>
      <p class="mt-4 text-base-content/70">
        Три выбора, пара минут — и вы управляете результатом. В боте всё точно так же.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-[1fr_1.1fr] lg:gap-10">
      <!-- Шаги (плотная раскладка — DESIGN §5) -->
      <div class="space-y-7">
        <fieldset>
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-sm font-bold text-primary-content"><span class="bg-primary px-1.5 py-0.5">шаг 1/3</span></span>
            <span class="text-lg font-semibold">Загрузите снимок</span>
          </legend>
          <div class="mt-3 flex gap-2 overflow-x-auto pb-1" data-config-group="dish">
            {dishes.map((d, i) => (
              <button
                type="button"
                class="config-chip group w-20 shrink-0 rounded-sm border-2 border-transparent p-1 transition-colors aria-pressed:border-primary"
                data-value={d.id}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <img
                  src={`/images/before/${d.id}.jpg`}
                  alt={`«До»: ${d.name.toLowerCase()}, снятый на телефон`}
                  class="aspect-square w-full rounded-sm object-cover"
                  loading="lazy"
                  width="144"
                  height="144"
                />
                <span class="mt-1 block text-center text-xs font-medium text-base-content/70 group-aria-pressed:text-base-content">{d.name}</span>
              </button>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-sm font-bold text-primary-content"><span class="bg-primary px-1.5 py-0.5">шаг 2/3</span></span>
            <span class="text-lg font-semibold">Выберите стиль</span>
          </legend>
          <div class="mt-3 grid grid-cols-2 gap-2" data-config-group="style">
            {styles.map((s, i) => (
              <button
                type="button"
                class="config-chip flex min-h-11 items-center gap-3 rounded-sm border-2 border-base-300 bg-base-100 px-3 py-2 text-left text-sm font-medium transition-colors aria-pressed:border-primary"
                data-value={s.id}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="h-6 w-6 shrink-0 rounded-sm" style={`background: linear-gradient(145deg, ${s.from}, ${s.to})`} aria-hidden="true"></span>
                {s.name}
              </button>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-sm font-bold text-primary-content"><span class="bg-primary px-1.5 py-0.5">шаг 3/3</span></span>
            <span class="text-lg font-semibold">Локация / фон</span>
          </legend>
          <div class="mt-3 flex flex-wrap gap-2" data-config-group="location">
            {locations.map((l, i) => (
              <button
                type="button"
                class="config-chip min-h-11 rounded-sm border-2 border-base-300 bg-base-100 px-4 text-sm font-medium transition-colors aria-pressed:border-primary"
                data-value={l.id}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                {l.name}
              </button>
            ))}
          </div>
        </fieldset>
      </div>

      <!-- Результат -->
      <div class="lg:sticky lg:top-24 lg:self-start">
        <div id="config-frame" class="config-result rounded-sm p-4 shadow-frame-warm transition-colors duration-300 md:p-6" style="background:#15161A">
          <img
            id="config-result-img"
            src="/images/after/burger.jpg"
            alt="Готовый кадр: бургер, стиль «Тёмная драма», локация «Студия»"
            class="aspect-[4/3] w-full rounded-sm object-cover"
            width="800"
            height="600"
            loading="lazy"
          />
        </div>
        <p id="config-meta" class="mt-3 flex flex-wrap justify-between gap-2 font-mono text-xs font-medium tracking-widest text-base-content/60">
          <span id="config-meta-text">бургер · тёмная драма · студия</span>
          <span id="config-counter">кадр 01/05</span>
        </p>
        <p class="mt-3 text-sm text-base-content/70">
          Превью иллюстративно: готовые комбинации «блюдо × стиль × локация» появятся после генерации набора.
        </p>
        <div class="mt-6 flex flex-col items-start gap-2">
          <a href={BOT_URL} target="_blank" rel="noopener" class="btn btn-primary btn-lg rounded-full px-9 shadow-shutter">
            {CTA_LABEL}
          </a>
          <p class="font-mono text-sm font-medium text-base-content/70">соберёте своё — прямо в боте, первое фото бесплатно</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initConfigurator() {
    const img = document.getElementById('config-result-img') as HTMLImageElement | null;
    const frame = document.getElementById('config-frame');
    const metaText = document.getElementById('config-meta-text');
    const counter = document.getElementById('config-counter');
    if (!img || !frame || !metaText || !counter) return;

    const dishNames: Record<string, string> = {
      burger: 'бургер', pasta: 'паста', cake: 'торт', dessert: 'десерт', bento: 'бенто-торт',
    };
    const dishOrder = ['burger', 'pasta', 'cake', 'dessert', 'bento'];
    const styleNames: Record<string, string> = {
      drama: 'тёмная драма', airy: 'светлый и воздушный', rustic: 'домашний рустик', fine: 'fine dining',
    };
    const styleFilters: Record<string, string> = {
      drama: 'brightness(0.94) contrast(1.1)',
      airy: 'brightness(1.07) contrast(0.97)',
      rustic: 'sepia(0.16) saturate(1.08)',
      fine: 'contrast(1.07) saturate(0.92)',
    };
    const locationNames: Record<string, string> = { studio: 'студия', marble: 'мрамор', wood: 'дерево' };
    const locationMats: Record<string, string> = { studio: '#15161A', marble: '#B9B9B4', wood: '#4A2F1C' };

    const state = { dish: 'burger', style: 'drama', location: 'studio' };

    // предзагрузка всех «после»-кадров, чтобы переключение было без прыжков
    dishOrder.forEach((d) => { new Image().src = `/images/after/${d}.jpg`; });

    function render() {
      const src = `/images/after/${state.dish}.jpg`;
      const apply = () => {
        img!.src = src;
        img!.style.filter = styleFilters[state.style];
        img!.alt = `Готовый кадр: ${dishNames[state.dish]}, стиль «${styleNames[state.style]}», локация «${locationNames[state.location]}»`;
        const done = () => img!.removeAttribute('data-hidden');
        if (img!.complete) done();
        else img!.addEventListener('load', done, { once: true });
      };
      img!.setAttribute('data-hidden', '');
      window.setTimeout(apply, 120);

      frame!.style.background = locationMats[state.location];
      metaText!.textContent = `${dishNames[state.dish]} · ${styleNames[state.style]} · ${locationNames[state.location]}`;
      counter!.textContent = `кадр 0${dishOrder.indexOf(state.dish) + 1}/05`;
    }

    document.querySelectorAll<HTMLElement>('[data-config-group]').forEach((group) => {
      const key = group.dataset.configGroup as keyof typeof state;
      group.querySelectorAll<HTMLButtonElement>('.config-chip').forEach((chip) => {
        chip.addEventListener('click', () => {
          state[key] = chip.dataset.value!;
          group.querySelectorAll('.config-chip').forEach((c) =>
            c.setAttribute('aria-pressed', c === chip ? 'true' : 'false'),
          );
          render();
        });
      });
    });
  }

  initConfigurator();
</script>

<style>
  /* aria-pressed как источник стиля выбранной опции */
  .config-chip[aria-pressed='true'] {
    border-color: oklch(var(--p));
  }
</style>
