---
// Лендинг «Манит» — структура по manitfood-landing-structure.md:
// расхождение (hero → до/после → развилка → сегмент-зона) →
// схождение (конфигуратор → тарифы → FAQ → финальный CTA).
import SeoJsonLd from '@/components/SeoJsonLd.astro';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import BeforeAfter from '@/components/BeforeAfter.astro';
import SegmentZone from '@/components/SegmentZone.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import Pricing from '@/components/Pricing.astro';
import Faq from '@/components/Faq.astro';
import CtaSection from '@/components/CtaSection.astro';
import Footer from '@/components/Footer.astro';
import { BOT_URL, SITE_URL } from '@/lib/site';

const organizationSchema = {
  '@type': 'Organization' as const,
  name: 'Манит (ManitFood)',
  url: SITE_URL,
  logo: `${SITE_URL}/logo.png`,
  sameAs: [BOT_URL],
};

const productSchema = {
  '@type': 'Product' as const,
  name: 'Манит — ИИ-фотостудия еды в Telegram',
  description:
    'Профессиональные фото блюд из снимков на телефон: студийный результат за минуты, без фотографа и реквизита. Первое фото — бесплатно.',
  image: `${SITE_URL}/og-image.jpg`,
  brand: { '@type': 'Brand' as const, name: 'Манит' },
  offers: {
    '@type': 'Offer' as const,
    price: '0',
    priceCurrency: 'RUB',
    availability: 'https://schema.org/InStock',
  },
};
---

<Layout
  title="ИИ-фотостудия еды в Telegram — фото блюда с телефона как из студии"
  description="Телеграм-бот Манит превращает снимок блюда с телефона в профессиональное фото для меню, доставки и соцсетей. Без фотографа и реквизита. Первое фото — бесплатно."
>
  <SeoJsonLd type="Organization" data={organizationSchema} />
  <SeoJsonLd type="Product" data={productSchema} />

  <Header />
  <main>
    <Hero />
    <BeforeAfter />
    <SegmentZone />
    <HowItWorks />
    <Pricing />
    <Faq />
    <CtaSection />
  </main>
  <Footer />
</Layout>
